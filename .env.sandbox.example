# ==============================================================================
# CONSUMA — Sandbox Operacional (EXEMPLO)
# Copiar para `.env.sandbox` (arquivo ignorado pelo git) e ajustar valores.
# ==============================================================================

# Perfil e porta
SPRING_PROFILES_ACTIVE=sandbox
SANDBOX_API_PORT=8080

# Credenciais (seed SANDBOX) — NUNCA usar defaults óbvios em servidor
SANDBOX_ADMIN_USERNAME=admin
SANDBOX_ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# Base URLs
APP_BASE_URL=http://localhost:8080/api
CLIENT_APP_URL=http://localhost:3000

# CORS (env var mapeia para `cors.allowed-origins`)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ==============================================================================
# Banco (PostgreSQL sandbox)
# ==============================================================================
DB_HOST=postgres-sandbox
DB_PORT=5432
DB_NAME=restaurante_sandbox_db
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# ==============================================================================
# Secrets (NUNCA usar defaults óbvios em servidor)
# - Recomendação: `openssl rand -hex 32`
# ==============================================================================
JWT_SECRET=CHANGE_ME_STRONG_JWT_SECRET_64CHARS_MIN
DEVICE_TOKEN_HASH_SECRET=CHANGE_ME_STRONG_DEVICE_TOKEN_HASH_SECRET
SYNC_CURSOR_HMAC_SECRET=CHANGE_ME_STRONG_SYNC_CURSOR_HMAC_SECRET
CONSUMA_OTP_HASH_PEPPER=CHANGE_ME_STRONG_OTP_HASH_PEPPER
CONSUMA_OTP_LENGTH=4
CONSUMA_OTP_MOCK_ENABLED=false
CONSUMA_SNAPSHOT_HMAC_SECRET_V1=CHANGE_ME_STRONG_SNAPSHOT_HMAC_SECRET_V1

# Opcional (aliases já usados no app; manter coerência do key-id)
SNAPSHOT_SIGNATURE_KEY_ID=platform-snapshot-key-v1
SNAPSHOT_SIGNATURE_ACTIVE_KEY_ID=platform-snapshot-key-v1

# ==============================================================================
# AppyPay (sandbox inicial em mock controlado)
# ==============================================================================
# Env var mapeia para `app.payment.appypay.mock`
APP_PAYMENT_APPYPAY_MOCK=true
APPYPAY_WEBHOOK_SECRET=CHANGE_ME_STRONG_APPYPAY_WEBHOOK_SECRET
# Em sandbox, preferir signature REQUIRED=true (script de smoke calcula HMAC)
APPYPAY_WEBHOOK_SIGNATURE_REQUIRED=true

# ==============================================================================
# SMS (TelcoSMS real para validar OTP público)
# ==============================================================================
# Env var legada mapeia para `app.notification.telcosms.mock`
APP_NOTIFICATION_TELCOSMS_MOCK=false
TELCOSMS_MOCK=false
TELCOSMS_BASE_URL=https://www.telcosms.co.ao
TELCOSMS_API_KEY=preencher
CONSUMA_SMS_PROVIDER=telcosms
CONSUMA_SMS_ENABLED=true
CONSUMA_SMS_BASE_URL=https://www.telcosms.co.ao
CONSUMA_SMS_API_KEY=preencher
CONSUMA_SMS_MOCK=false
CONSUMA_SMS_SENDER_ID=CONSUMA

# ==============================================================================
# Scheduler (opcional em sandbox)
# ==============================================================================
SPRING_TASK_SCHEDULING_ENABLED=true

# ==============================================================================
# MinIO (opcional; não bloqueia startup por padrão)
# ==============================================================================
MINIO_ENDPOINT=http://host.docker.internal:9000
MINIO_PUBLIC_URL=http://localhost:9000/restaurante-images
