# Copie para .env.prod e preencha sem versionar.

# Banco de dados Postgres
POSTGRES_DB=restauracao_prod
POSTGRES_USER=restauracao
POSTGRES_PASSWORD=trocar-por-senha-forte

# URL pública da API. Para ngrok, use: https://SEU-SUBDOMINIO.ngrok-free.app/api
APP_BASE_URL=https://SEU-TUNEL.ngrok-free.app/api
CORS_ALLOWED_ORIGINS=https://SEU-FRONTEND

# Segurança
JWT_SECRET=trocar-por-secret-hex-ou-base64-com-256-bits-minimo
SOCIO_JWT_SECRET=trocar-se-usar-token-dos-socios
SOCIO_JWT_ISSUER=associagest

# AppyPay real
APPYPAY_MOCK=false
APPYPAY_BASE_URL=https://gwy-api.appypay.co.ao/v2.0
APPYPAY_TOKEN_URL=https://login.microsoftonline.com/auth.appypay.co.ao/oauth2/token
APPYPAY_CLIENT_ID=preencher
APPYPAY_CLIENT_SECRET=preencher
APPYPAY_RESOURCE=preencher
APPYPAY_METHOD_GPO=GPO_1AD9C67D-B385-45EF-B81F-374CF3A3B2D0
APPYPAY_METHOD_REF=REF_0472ED3E-6F06-4A1E-9884-446578391FE8
APPYPAY_WEBHOOK_SECRET=preencher
APPYPAY_WEBHOOK_SIGNATURE_REQUIRED=true
APPYPAY_TIMEOUT_MS=20000

# TelcoSMS real
TELCOSMS_MOCK=false
TELCOSMS_BASE_URL=https://www.telcosms.co.ao
TELCOSMS_API_KEY=preencher

# MinIO/arquivos
MINIO_ENDPOINT=http://host.docker.internal:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=restaurante-images
MINIO_PUBLIC_URL=http://localhost:9000/restaurante-images
