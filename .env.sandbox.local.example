# ==============================================================================
# CONSUMA — Sandbox Local Docker (EXEMPLO)
# Copiar para `.env.sandbox.local` e ajustar os valores locais.
# Este arquivo de exemplo pode ir para o Git; `.env.sandbox.local` não.
# ==============================================================================

SPRING_PROFILES_ACTIVE=sandbox-local
SANDBOX_LOCAL_API_PORT=8081

POSTGRES_DB=consuma_sandbox
POSTGRES_USER=consuma
POSTGRES_PASSWORD=change_me_local

DB_HOST=postgres-local
DB_PORT=5432
DB_NAME=consuma_sandbox
DB_USER=consuma
DB_PASSWORD=change_me_local

APP_BASE_URL=http://localhost:8081/api
CONSUMA_PUBLIC_BASE_URL=http://localhost:8081
CLIENT_APP_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://localhost:8080,http://localhost:8081,http://localhost:8082

JWT_SECRET=change_me_with_long_random_secret_32_plus_chars
DEVICE_TOKEN_HASH_SECRET=change_me_device_secret_32_plus_chars
SYNC_CURSOR_HMAC_SECRET=change_me_cursor_secret_32_plus_chars
CONSUMA_SNAPSHOT_HMAC_SECRET_V1=change_me_snapshot_secret_32_plus_chars
CONSUMA_TX_EVIDENCE_HMAC_KEY_V1=change_me_tx_evidence_secret_32_plus_chars

SANDBOX_ADMIN_USERNAME=admin
SANDBOX_ADMIN_PASSWORD=change_me_strong_admin_password
SANDBOX_ADMIN_EMAIL=admin@sandbox.local
SANDBOX_ADMIN_TELEFONE=+244900000000

APP_PAYMENT_APPYPAY_MOCK=true
APPYPAY_CLIENT_ID=sandbox_dummy
APPYPAY_CLIENT_SECRET=sandbox_dummy
APPYPAY_WEBHOOK_SECRET=sandbox_dummy
APPYPAY_WEBHOOK_SIGNATURE_REQUIRED=true

APP_NOTIFICATION_TELCOSMS_MOCK=true
SPRING_TASK_SCHEDULING_ENABLED=true

MINIO_ENDPOINT=http://host.docker.internal:9000
MINIO_PUBLIC_URL=http://localhost:9000/restaurante-images
